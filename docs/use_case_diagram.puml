UC3 ..> UC2 : <<include>>
UC4 ..> UC3 : <<include>>
UC7 ..> UC3 : <<include>>
UC9 ..> UC3 : <<include>>
UC8 ..> UC7 : <<include>>
UC10 ..> UC7 : <<include>>
UC12 ..> UC3 : <<include>>
UC30 ..> UC29 : <<include>>
UC31 ..> UC29 : <<include>>
UC32 ..> UC29 : <<include>>
UC33 ..> UC30 : <<include>>
UC34 ..> UC30 : <<include>>
UC35 ..> UC32 : <<include>>
UC36 ..> UC35 : <<include>>
UC37 ..> UC35 : <<include>>
UC38 ..> UC34 : <<include>>
UC19 ..> UC32 : <<include>>
UC45 ..> UC32 : <<include>>

' Extend relationships
UC5 ..> UC4 : <<extend>>
UC6 ..> UC1 : <<extend>>
UC16 ..> UC14 : <<extend>>
UC25 ..> UC23 : <<extend>>
UC41 ..> UC39 : <<extend>>
UC44 ..> UC43 : <<extend>>

' System interactions
UC3 ..> UC56 : <<uses>>
UC56 ..> UC55 : <<include>>
UC4 ..> UC57 : <<uses>>
UC4 ..> UC58 : <<uses>>

note right of child
  Primary user who practices
  handwriting and earns rewards
end note

note right of parent
  Manages child profiles,
  monitors progress, and
  configures app settings
end note

note right of admin
  Oversees the entire system,
  manages users, and views
  analytics through dashboard
end note

note right of ml
  On-device ML system that
  evaluates handwriting quality
  without sending data externally
end note

@enduml
